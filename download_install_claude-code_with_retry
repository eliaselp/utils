#!/bin/bash

set -e

# Parse command line arguments
TARGET="$1"  # Optional target parameter

# Validate target if provided
if [[ -n "$TARGET" ]] && [[ ! "$TARGET" =~ ^(stable|latest|[0-9]+\.[0-9]+\.[0-9]+(-[^[:space:]]+)?)$ ]]; then
    echo "Usage: $0 [stable|latest|VERSION]" >&2
    exit 1
fi

GCS_BUCKET="https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases"
DOWNLOAD_DIR="$HOME/.claude/downloads"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLAUDE_BIN_DIR="$SCRIPT_DIR/claude_bin"

# Check for required dependencies
DOWNLOADER=""
if command -v wget >/dev/null 2>&1; then
    DOWNLOADER="wget"
elif command -v curl >/dev/null 2>&1; then
    DOWNLOADER="curl"
else
    echo "Either wget or curl is required but neither is installed" >&2
    exit 1
fi

# Check if jq is available (optional)
HAS_JQ=false
if command -v jq >/dev/null 2>&1; then
    HAS_JQ=true
fi

# Download function that works with both curl and wget (prefers wget with -c for resume)
download_file() {
    local url="$1"
    local output="$2"
    
    if [ "$DOWNLOADER" = "wget" ]; then
        if [ -n "$output" ]; then
            wget -c -q --show-progress -O "$output" "$url"
        else
            wget -q -O - "$url"
        fi
    elif [ "$DOWNLOADER" = "curl" ]; then
        if [ -n "$output" ]; then
            curl -C - -fsSL -o "$output" "$url"
        else
            curl -fsSL "$url"
        fi
    else
        return 1
    fi
}

# Simple JSON parser for extracting checksum when jq is not available
get_checksum_from_manifest() {
    local json="$1"
    local platform="$2"
    
    # Normalize JSON to single line and extract checksum
    json=$(echo "$json" | tr -d '\n\r\t' | sed 's/ \+/ /g')
    
    # Extract checksum for platform using bash regex
    if [[ $json =~ \"$platform\"[^}]*\"checksum\"[[:space:]]*:[[:space:]]*\"([a-f0-9]{64})\" ]]; then
        echo "${BASH_REMATCH[1]}"
        return 0
    fi
    
    return 1
}

# Detect platform
case "$(uname -s)" in
    Darwin) os="darwin" ;;
    Linux) os="linux" ;;
    MINGW*|MSYS*|CYGWIN*) echo "Windows is not supported by this script. See https://code.claude.com/docs for installation options." >&2; exit 1 ;;
    *) echo "Unsupported operating system: $(uname -s). See https://code.claude.com/docs for supported platforms." >&2; exit 1 ;;
esac

case "$(uname -m)" in
    x86_64|amd64) arch="x64" ;;
    arm64|aarch64) arch="arm64" ;;
    *) echo "Unsupported architecture: $(uname -m)" >&2; exit 1 ;;
esac

# Detect Rosetta 2 on macOS: if the shell is running as x64 under Rosetta on an ARM Mac,
# download the native arm64 binary instead of the x64 one
if [ "$os" = "darwin" ] && [ "$arch" = "x64" ]; then
    if [ "$(sysctl -n sysctl.proc_translated 2>/dev/null)" = "1" ]; then
        arch="arm64"
    fi
fi

# Check for musl on Linux and adjust platform accordingly
if [ "$os" = "linux" ]; then
    if [ -f /lib/libc.musl-x86_64.so.1 ] || [ -f /lib/libc.musl-aarch64.so.1 ] || ldd /bin/ls 2>&1 | grep -q musl; then
        platform="linux-${arch}-musl"
    else
        platform="linux-${arch}"
    fi
else
    platform="${os}-${arch}"
fi

# Create necessary directories
mkdir -p "$DOWNLOAD_DIR"
mkdir -p "$CLAUDE_BIN_DIR"

# Always download latest version (which has the most up-to-date installer)
echo "Fetching latest version information..."
version=$(download_file "$GCS_BUCKET/latest")

# Download manifest and extract checksum
echo "Downloading manifest for version $version..."
manifest_json=$(download_file "$GCS_BUCKET/$version/manifest.json")

# Use jq if available, otherwise fall back to pure bash parsing
if [ "$HAS_JQ" = true ]; then
    checksum=$(echo "$manifest_json" | jq -r ".platforms[\"$platform\"].checksum // empty")
else
    checksum=$(get_checksum_from_manifest "$manifest_json" "$platform")
fi

# Validate checksum format (SHA256 = 64 hex characters)
if [ -z "$checksum" ] || [[ ! "$checksum" =~ ^[a-f0-9]{64}$ ]]; then
    echo "Platform $platform not found in manifest" >&2
    exit 1
fi

# Download and verify to claude_bin directory
binary_name="claude-$version-$platform"
binary_path="$CLAUDE_BIN_DIR/$binary_name"
echo "Downloading Claude Code binary to $binary_path..."
if ! download_file "$GCS_BUCKET/$version/$platform/claude" "$binary_path"; then
    echo "Download failed" >&2
    rm -f "$binary_path"
    exit 1
fi

# Pick the right checksum tool
if [ "$os" = "darwin" ]; then
    actual=$(shasum -a 256 "$binary_path" | cut -d' ' -f1)
else
    actual=$(sha256sum "$binary_path" | cut -d' ' -f1)
fi

echo "Verifying checksum..."
if [ "$actual" != "$checksum" ]; then
    echo "Checksum verification failed" >&2
    echo "Expected: $checksum" >&2
    echo "Got: $actual" >&2
    rm -f "$binary_path"
    exit 1
fi

chmod +x "$binary_path"
echo "✅ Binary downloaded and verified successfully!"

# Copy to downloads directory
echo "Copying binary to $DOWNLOAD_DIR..."
cp "$binary_path" "$DOWNLOAD_DIR/"

# Create installation script
INSTALL_SCRIPT="$SCRIPT_DIR/install_claude.sh"
echo "Creating installation script at $INSTALL_SCRIPT..."

cat > "$INSTALL_SCRIPT" << 'EOF'
#!/bin/bash

set -e

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLAUDE_BIN_DIR="$SCRIPT_DIR/claude_bin"
DOWNLOAD_DIR="$HOME/.claude/downloads"

# Find the latest binary in claude_bin directory
echo "Looking for Claude Code binary..."
binary_path=$(ls -t "$CLAUDE_BIN_DIR"/claude-* 2>/dev/null | head -n1)

if [ -z "$binary_path" ]; then
    echo "Error: No Claude Code binary found in $CLAUDE_BIN_DIR" >&2
    echo "Please run the download script first." >&2
    exit 1
fi

echo "Found binary: $binary_path"

# Parse target if provided
TARGET="$1"
if [[ -n "$TARGET" ]] && [[ ! "$TARGET" =~ ^(stable|latest|[0-9]+\.[0-9]+\.[0-9]+(-[^[:space:]]+)?)$ ]]; then
    echo "Usage: $0 [stable|latest|VERSION]" >&2
    exit 1
fi

# Run claude install to set up launcher and shell integration
echo "Setting up Claude Code..."
"$binary_path" install ${TARGET:+"$TARGET"}

# Also ensure the binary is available in downloads directory
echo "Ensuring binary is available in downloads directory..."
if [ -f "$DOWNLOAD_DIR/$(basename "$binary_path")" ]; then
    echo "Binary already present in $DOWNLOAD_DIR"
else
    echo "Copying binary to $DOWNLOAD_DIR..."
    cp "$binary_path" "$DOWNLOAD_DIR/"
fi

echo ""
echo "✅ Installation complete!"
echo ""
echo "Claude Code has been installed and configured."
echo "You can now run 'claude' from your terminal."
EOF

chmod +x "$INSTALL_SCRIPT"

echo ""
echo "========================================="
echo "✅ Download completed successfully!"
echo "========================================="
echo ""
echo "Binary location: $binary_path"
echo "Backup location: $DOWNLOAD_DIR/$binary_name"
echo "Installation script: $INSTALL_SCRIPT"
echo ""
echo "To complete the installation, run:"
echo "  $INSTALL_SCRIPT ${TARGET:+"$TARGET"}"
echo ""
echo "Or if you want to run the installation with a specific target:"
echo "  $INSTALL_SCRIPT stable"
echo "  $INSTALL_SCRIPT latest"
echo "  $INSTALL_SCRIPT 1.0.0"
echo ""
